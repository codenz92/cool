# Debug tok_type

def tok_type(t):
    print("tok_type called with: " + str(t) + ", type=" + str(type(t)))
    if type(t) == tuple:
        print("  it's a tuple, len=" + str(len(t)))
        if len(t) > 0:
            print("  returning: " + str(t[0]))
            return t[0]
    print("  returning: " + str(t))
    return t

tok_type(("NUM", 1))