# Debug token type matching

def tok_type(t):
    if type(t) == tuple and len(t) > 0:
        return t[0]
    return t

def is_type(t, expected):
    return tok_type(t) == expected

tests = [
    ("NUM", 1),
    ("STR", "hello"),
    "print",
    "(",
]

for t in tests:
    print("t=" + str(t) + ", is_type(t,'NUM')=" + str(is_type(t, 'NUM')))