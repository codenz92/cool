# Try try/catch for safe type checking

def get_first(v):
    try:
        return v[0]
    except:
        return nil

t = ("NUM", 1)
l = [1, 2, 3]
n = 42
s = "hello"

print("get_first(t)=" + str(get_first(t)))
print("get_first(l)=" + str(get_first(l)))
print("get_first(n)=" + str(get_first(n)))
print("get_first(s)=" + str(get_first(s)))

# Now use this to check if it's a tuple
def is_tuple(v):
    first = get_first(v)
    return first != nil and type(first) == str

print("\nis_tuple(t)=" + str(is_tuple(t)))
print("is_tuple(l)=" + str(is_tuple(l)))
print("is_tuple(n)=" + str(is_tuple(n)))
print("is_tuple(s)=" + str(is_tuple(s)))