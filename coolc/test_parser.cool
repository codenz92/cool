# Parser test

# --- Minimal lexer for testing ---
def is_alpha(c):
    return c != nil and ((c >= 'a' and c <= 'z') or (c >= 'A' and c <= 'Z'))

def is_digit(c):
    return c != nil and c >= '0' and c <= '9'

class Lexer:
    def __init__(self, source):
        self.source = source
        self.pos = 0

    def peek(self):
        if self.pos < len(self.source):
            return self.source[self.pos]
        return nil

    def advance(self):
        c = self.peek()
        if c != nil:
            self.pos += 1
        return c

    def tokenize(self):
        tokens = []
        while self.peek() != nil:
            c = self.peek()
            if c == ' ' or c == '\t' or c == '\n':
                self.advance()
                continue
            if is_digit(c):
                n = ""
                while self.peek() != nil and is_digit(self.peek()):
                    n += self.peek()
                    self.advance()
                tokens.append(('NUM', int(n)))
            elif is_alpha(c):
                id = ""
                while self.peek() != nil and (is_alpha(self.peek()) or is_digit(self.peek())):
                    id += self.peek()
                    self.advance()
                tokens.append(('IDENT', id))
            elif c == '(':
                self.advance()
                tokens.append(('LPAREN', '('))
            elif c == ')':
                self.advance()
                tokens.append(('RPAREN', ')'))
            elif c == ':':
                self.advance()
                tokens.append(('COLON', ':'))
            elif c == '+':
                self.advance()
                tokens.append(('PLUS', '+'))
            elif c == '-':
                self.advance()
                tokens.append(('MINUS', '-'))
            elif c == '*':
                self.advance()
                tokens.append(('STAR', '*'))
            elif c == '>':
                self.advance()
                tokens.append(('GT', '>'))
            elif c == '=':
                self.advance()
                tokens.append(('ASSIGN', '='))
            else:
                self.advance()
        tokens.append(('EOF', nil))
        return tokens

# --- Simple recursive descent parser ---
class Parser:
    def __init__(self, tokens):
        self.tokens = tokens
        self.pos = 0

    def peek(self):
        return self.tokens[self.pos]

    def advance(self):
        self.pos += 1
        return self.tokens[self.pos - 1]

    def parse(self):
        stmts = []
        while self.peek()[0] != 'EOF':
            stmts.append(self.parse_stmt())
        return stmts

    def parse_stmt(self):
        tok = self.peek()
        if tok[0] == 'IDENT' and tok[1] == 'def':
            return self.parse_def()
        if tok[0] == 'IDENT' and tok[1] == 'if':
            return self.parse_if()
        if tok[0] == 'IDENT' and tok[1] == 'return':
            return self.parse_return()
        return self.parse_expr_stmt()

    def parse_def(self):
        self.advance()  # 'def'
        name = self.advance()[1]
        self.advance()  # '('
        params = []
        while self.peek()[0] != 'RPAREN':
            params.append(self.advance()[1])
            if self.peek()[0] == 'COMMA':
                self.advance()
        self.advance()  # ')'
        self.advance()  # ':'
        body = self.parse_block()
        return ('def', name, params, body)

    def parse_if(self):
        self.advance()  # 'if'
        cond = self.parse_expr()
        self.advance()  # ':'
        then = self.parse_block()
        else_branch = nil
        if self.peek()[0] == 'IDENT' and self.peek()[1] == 'else':
            self.advance()
            self.advance()  # ':'
            else_branch = self.parse_block()
        return ('if', cond, then, else_branch)

    def parse_return(self):
        self.advance()  # 'return'
        if self.peek()[0] == 'NEWLINE' or self.peek()[0] == 'EOF':
            return ('return', ('nil', nil))
        val = self.parse_expr()
        return ('return', val)

    def parse_block(self):
        stmts = []
        while self.peek()[0] != 'EOF' and self.peek()[0] != 'IDENT':
            stmts.append(self.parse_stmt())
        return stmts

    def parse_expr_stmt(self):
        expr = self.parse_expr()
        return ('expr', expr)

    def parse_expr(self):
        return self.parse_add()

    def parse_add(self):
        left = self.parse_term()
        while self.peek()[0] == 'PLUS' or self.peek()[0] == 'MINUS':
            op = self.advance()[0]
            right = self.parse_term()
            left = (op, left, right)
        return left

    def parse_term(self):
        left = self.parse_factor()
        while self.peek()[0] == 'STAR':
            self.advance()
            right = self.parse_factor()
            left = ('*', left, right)
        return left

    def parse_factor(self):
        tok = self.peek()
        if tok[0] == 'NUM':
            self.advance()
            return ('num', tok[1])
        if tok[0] == 'IDENT':
            name = self.advance()[1]
            if self.peek()[0] == 'LPAREN':
                self.advance()  # (
                args = []
                while self.peek()[0] != 'RPAREN':
                    args.append(self.parse_expr())
                    if self.peek()[0] == 'COMMA':
                        self.advance()
                self.advance()  # )
                return ('call', name, args)
            return ('var', name)
        if tok[0] == 'LPAREN':
            self.advance()
            expr = self.parse_expr()
            self.advance()  # )
            return expr
        return ('nil', nil)

# Test
source = """
def add(x, y):
    return x + y

result = add(1, 2)
"""

lexer = Lexer(source)
tokens = lexer.tokenize()
print("Tokens: " + str(len(tokens)))

parser = Parser(tokens)
ast = parser.parse()
print("AST:")
print(ast)