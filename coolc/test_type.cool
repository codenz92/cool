# Test type comparison

t = ("NUM", 1)
print("type(t)=" + str(type(t)))
print("type(t) == tuple: " + str(type(t) == tuple))

# Try using the runtime's type function
print("type(t).__name__: " + str(type(t).__name__))

# Check if it's a tuple using __name__
if type(t).__name__ == "tuple":
    print("It's a tuple by name!")