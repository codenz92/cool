# Simple lexer test
source = "x = 1 + 2"

class Lexer:
    def __init__(self, source):
        self.source = source
        self.pos = 0

    def peek(self):
        if self.pos < len(self.source):
            return self.source[self.pos]
        return nil

    def advance(self):
        c = self.peek()
        if c != nil:
            self.pos += 1
        return c

    def tokenize(self):
        tokens = []
        while self.peek() != nil:
            c = self.peek()
            if c == ' ' or c == '\t' or c == '\n':
                self.advance()
                continue
            if c >= '0' and c <= '9':
                n = ""
                while self.peek() != nil and self.peek() >= '0' and self.peek() <= '9':
                    n += self.peek()
                    self.advance()
                tokens.append(('NUM', int(n)))
            elif c >= 'a' and c <= 'z' or c >= 'A' and c <= 'Z' or c == '_':
                id = ""
                while self.peek() != nil and (self.peek() >= 'a' and self.peek() <= 'z' or self.peek() >= 'A' and self.peek() <= 'Z' or self.peek() >= '0' and self.peek() <= '9' or self.peek() == '_'):
                    id += self.peek()
                    self.advance()
                tokens.append(('IDENT', id))
            elif c == '=':
                self.advance()
                if self.peek() == '=':
                    self.advance()
                    tokens.append(('EQ', '=='))
                else:
                    tokens.append(('ASSIGN', '='))
            elif c == '+':
                self.advance()
                tokens.append(('PLUS', '+'))
            else:
                self.advance()
        tokens.append(('EOF', nil))
        return tokens

lexer = Lexer(source)
tokens = lexer.tokenize()
print(tokens)