import base64
import bytes
import hashlib
import json
import socket
import url

private def _fail(message):
    raise "websocket: " + message

private def _guid():
    return "258EAFA5-E914-47DA-95CA-C5AB0DC85B11"

private def _get(mapping, key, default=nil):
    if mapping != nil and type(mapping) == "dict" and key in mapping:
        return mapping[key]
    return default

private def _tail(text, start):
    source = str(text)
    begin = int(start)
    if begin < 0:
        begin = 0
    if begin > len(source):
        begin = len(source)
    return source[begin:len(source)]

private def _rstrip_chars(text, chars):
    source = str(text)
    trim = str(chars)
    end = len(source)
    while end > 0 and trim.find(source[end - 1]) >= 0:
        end = end - 1
    return source[0:end]

private def _join_tail(parts, start):
    out = []
    idx = int(start)
    while idx < len(parts):
        out.append(parts[idx])
        idx = idx + 1
    return " ".join(out)

private def _normalize_headers(headers):
    out = {}
    if headers == nil:
        return out
    if type(headers) == "dict":
        for pair in headers.items():
            out[str(pair[0])] = str(pair[1])
        return out
    for item in headers:
        if type(item) == "tuple" or type(item) == "list":
            out[str(item[0])] = str(item[1])
            continue
        text = str(item)
        idx = text.find(":")
        if idx < 0:
            continue
        out[text[0:idx].strip()] = _tail(text, idx + 1).strip()
    return out

private def _header_lines(headers):
    out = []
    for pair in headers.items():
        out.append(str(pair[0]) + ": " + str(pair[1]))
    return out

def client_key(seed=nil):
    source = str(seed)
    if seed == nil:
        source = "cool-websocket"
    return base64.encode(bytes.from_hex(hashlib.md5(source)))

def accept_key(key):
    return base64.encode(bytes.from_hex(hashlib.sha1(str(key) + _guid())))

private def _target_parts(target):
    parsed = url.parse(target)
    scheme = _get(parsed, "scheme", "ws")
    if scheme != "ws" and scheme != "wss":
        _fail("only ws:// and wss:// URLs are supported")
    host = _get(parsed, "host", "")
    if host == "":
        _fail("websocket URL is missing a host")
    port = parsed.get("port")
    if port == nil:
        if scheme == "wss":
            port = 443
        else:
            port = 80
    path_value = _get(parsed, "path", "/")
    if path_value == "":
        path_value = "/"
    if parsed.get("query") != nil and parsed.get("query") != "":
        path_value = path_value + "?" + parsed.get("query")
    return {
        "scheme": scheme,
        "host": host,
        "port": int(port),
        "path": path_value,
        "parsed": parsed,
    }

def request(target, headers=nil, key=nil):
    parts = _target_parts(target)
    if key == nil:
        key = client_key(str(target))
    header_map = {
        "Host": parts["host"] + ":" + str(parts["port"]),
        "Upgrade": "websocket",
        "Connection": "Upgrade",
        "Sec-WebSocket-Version": "13",
        "Sec-WebSocket-Key": str(key),
    }
    extra = _normalize_headers(headers)
    for pair in extra.items():
        header_map[pair[0]] = pair[1]
    lines = ["GET " + parts["path"] + " HTTP/1.1"]
    for line in _header_lines(header_map):
        lines.append(line)
    lines.append("")
    lines.append("")
    return {"text": "\r\n".join(lines), "key": key, "parts": parts, "headers": header_map}

private def _read_headers(conn):
    lines = []
    while true:
        line = conn.readline()
        if line == "":
            break
        clean = _rstrip_chars(line, "\r\n")
        if clean == "":
            break
        lines.append(clean)
    return lines

private def _parse_header_block(lines):
    headers = {}
    first = ""
    if type(lines) == "str":
        lines = str(lines).split("\n")
    if len(lines) > 0:
        first = _rstrip_chars(lines[0], "\r")
    i = 1
    while i < len(lines):
        line = _rstrip_chars(lines[i], "\r")
        idx = line.find(":")
        if idx >= 0:
            headers[line[0:idx].strip().lower()] = _tail(line, idx + 1).strip()
        i = i + 1
    return {"first": first, "headers": headers}

def parse_request(lines):
    parsed = _parse_header_block(lines)
    first = parsed["first"]
    parts = first.split(" ")
    if len(parts) < 3:
        _fail("invalid websocket request line")
    return {
        "method": parts[0],
        "path": parts[1],
        "version": parts[2],
        "headers": parsed["headers"],
    }

def parse_response(lines):
    parsed = _parse_header_block(lines)
    first = parsed["first"]
    parts = first.split(" ")
    if len(parts) < 3:
        _fail("invalid websocket response line")
    return {
        "version": parts[0],
        "code": int(parts[1]),
        "reason": _join_tail(parts, 2),
        "headers": parsed["headers"],
    }

def connect(target, headers=nil, key=nil):
    req = request(target, headers, key)
    parts = req["parts"]
    conn = socket.connect(parts["host"], parts["port"])
    conn.send(req["text"])
    response = parse_response(_read_headers(conn))
    if response.get("code") != 101:
        _fail("server rejected websocket upgrade with " + str(response.get("code")))
    expected = accept_key(req["key"])
    if _get(_get(response, "headers", {}), "sec-websocket-accept") != expected:
        _fail("server returned an invalid Sec-WebSocket-Accept header")
    return {
        "socket": conn,
        "role": "client",
        "target": target,
        "response": response,
        "headers": req["headers"],
        "closed": false,
    }

def accept(conn, headers=nil):
    request_info = parse_request(_read_headers(conn))
    key = _get(_get(request_info, "headers", {}), "sec-websocket-key")
    if key == nil or key == "":
        _fail("websocket request is missing Sec-WebSocket-Key")
    response_headers = {
        "Upgrade": "websocket",
        "Connection": "Upgrade",
        "Sec-WebSocket-Accept": accept_key(key),
    }
    extra = _normalize_headers(headers)
    for pair in extra.items():
        response_headers[pair[0]] = pair[1]
    lines = ["HTTP/1.1 101 Switching Protocols"]
    for line in _header_lines(response_headers):
        lines.append(line)
    lines.append("")
    lines.append("")
    conn.send("\r\n".join(lines))
    return {
        "socket": conn,
        "role": "server",
        "request": request_info,
        "closed": false,
    }

def accept_client(listener, headers=nil):
    return accept(listener.accept(), headers)

private def _choose_mask(payload):
    key = []
    residue = 0
    while residue < 4:
        used = {}
        index = residue
        while index < len(payload):
            used[payload[index]] = true
            index = index + 4
        candidate = 1
        while candidate <= 255 and candidate in used:
            candidate = candidate + 1
        if candidate > 255:
            candidate = 255
        key.append(candidate)
        residue = residue + 1
    return key

private def _mask(payload, key):
    out = []
    i = 0
    while i < len(payload):
        out.append(payload[i] ^ key[i % 4])
        i = i + 1
    return out

private def _frame_bytes(opcode, payload, masked):
    data = bytes.coerce(payload)
    out = [0x80 | (int(opcode) & 0x0F)]
    length = len(data)
    if length < 126:
        out.append((masked and 0x80 or 0) | length)
    elif length <= 65535:
        out.append((masked and 0x80 or 0) | 126)
        for item in bytes.u16_be(length):
            out.append(item)
    else:
        out.append((masked and 0x80 or 0) | 127)
        for item in bytes.u64_be(length):
            out.append(item)
    if masked:
        key = _choose_mask(data)
        for item in key:
            out.append(item)
        data = _mask(data, key)
    for item in data:
        out.append(item)
    return out

private def _read_exact(conn, count):
    remaining = int(count)
    out = []
    while remaining > 0:
        chunk = conn.recv_bytes(remaining)
        if len(chunk) == 0:
            _fail("unexpected EOF while reading websocket frame")
        for item in chunk:
            out.append(int(item))
        remaining = remaining - len(chunk)
    return out

def send_frame(ws, opcode, payload=nil):
    masked = _get(ws, "role") == "client"
    data = []
    if payload != nil:
        data = bytes.coerce(payload)
    _get(ws, "socket").send_bytes(_frame_bytes(opcode, data, masked))
    return nil

def send_text(ws, text):
    return send_frame(ws, 1, bytes.from_string(text))

def send_json(ws, value):
    return send_text(ws, json.dumps(value))

def send_binary(ws, payload):
    return send_frame(ws, 2, payload)

def recv(ws):
    head = _read_exact(_get(ws, "socket"), 2)
    first = head[0]
    second = head[1]
    opcode = first & 0x0F
    masked = (second & 0x80) != 0
    length = second & 0x7F
    if length == 126:
        length = bytes.read_u16_be(_read_exact(_get(ws, "socket"), 2))
    elif length == 127:
        length = bytes.read_u64_be(_read_exact(_get(ws, "socket"), 8))
    mask_key = nil
    if masked:
        mask_key = _read_exact(_get(ws, "socket"), 4)
    payload = _read_exact(ws.get("socket"), length)
    if masked:
        payload = _mask(payload, mask_key)
    frame = {
        "fin": (first & 0x80) != 0,
        "opcode": opcode,
        "masked": masked,
        "bytes": payload,
    }
    if opcode == 1 or opcode == 8 or opcode == 9 or opcode == 10:
        frame["text"] = bytes.to_string(payload)
    if opcode == 9:
        send_frame(ws, 10, payload)
    if opcode == 8:
        ws["closed"] = true
    return frame

def recv_text(ws):
    while true:
        frame = recv(ws)
        if frame.get("opcode") == 1:
            return _get(frame, "text", "")
        if frame.get("opcode") == 8:
            return nil

def recv_json(ws):
    text = recv_text(ws)
    if text == nil:
        return nil
    return json.loads(text)

def close(ws, code=1000, reason=""):
    if _get(ws, "closed"):
        return nil
    payload = []
    for item in bytes.u16_be(int(code)):
        payload.append(item)
    for item in bytes.from_string(reason):
        payload.append(item)
    send_frame(ws, 8, payload)
    ws["closed"] = true
    return nil

def listen(host, port):
    return socket.listen(host, port)
