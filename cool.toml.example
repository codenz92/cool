# Example cool.toml - Cool project configuration
# Place this file in the root of your Cool project

[project]
name = "myapp"
version = "0.1.0"
main = "src/main.cool"

# Optional: output binary name (defaults to name if not specified)
# output = "myapp"

# Optional: additional source directories
# sources = ["src", "lib"]

# Optional: GNU linker script for kernel/freestanding builds.
# When set, `cool build` compiles to an object file and then invokes LLD
# (ld.lld) to link a kernel image: <output>.elf. Path is relative to this file.
# linker_script = "link.ld"

# Optional: default build profile for `cool build`
#
# [build]
# profile = "dev"          # dev, release, freestanding, or strict
# emit = "binary"          # binary, object, assembly, llvm-ir, staticlib, or sharedlib
# target = "x86_64-unknown-linux-gnu"  # optional explicit LLVM target triple
# cpu = "x86-64-v3"        # optional explicit LLVM target CPU
# cpu_features = "+popcnt" # optional explicit LLVM target feature string
# entry = "_start"         # optional explicit linker entry for no-libc/kernel outputs
# incremental = true       # optional: enable the local native build cache
# reproducible = true      # optional: normalize paths and deterministic tool output
# debug = true             # optional: emit DWARF/line tables for native builds
# no_libc = false          # optional: skip the hosted runtime/libc assumptions where supported
#
# Optional: pin the external toolchain used for native builds.
#
# [toolchain]
# cool = "1.0.0"
# cc = "clang"
# ar = "llvm-ar"
# lld = "ld.lld"

# Optional: native linker inputs used by `cool build`
#
# [native]
# libraries = ["sqlite3"]                 # link -lsqlite3
# # libraries = [{ name = "mylib", kind = "static" }]
# search = ["native/lib"]                 # extra -L search paths
# rpath = ["@loader_path/../lib"]         # runtime library search path

# Optional: dependencies, imported by dependency name
#
# [dependencies]
# toolkit = { path = "../toolkit" }
# theme = { git = "https://github.com/acme/theme.git" }
#
# Use `cool add ...` to edit this table and `cool install` to fetch git deps
# into .cool/deps and write cool.lock. Use `cool install --locked` in CI or
# release flows to verify the existing lockfile and dependency checksums.

# Optional: manifest tasks for `cool task`
#
# [tasks.run]
# description = "Run the app"
# run = "cool src/main.cool"
#
# [tasks.build]
# description = "Build a native binary"
# run = "cool build"
#
# [tasks.test]
# description = "Run Cool tests"
# run = "cool test"
#
# [tasks.publish]
# description = "Validate and package a source distribution"
# run = "cool publish"
#
# [tasks.bench]
# description = "Run native benchmarks"
# run = "cool bench"
#
# [tasks.doc]
# description = "Generate API docs"
# run = "cool doc --output docs/API.md"
#
# [tasks.fmt]
# description = "Format Cool source files"
# run = "cool fmt"
