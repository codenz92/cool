# All working LLVM features
print("=== lists ===")
lst = [1, 2, 3]
print(lst)

print("=== for loop ===")
for x in [1, 2, 3]:
    print(x)

print("=== range ===")
print(range(0, 3))

print("=== functions ===")
def double(x):
    return x * 2
print(double(5))

print("=== recursion ===")
def factorial(n):
    if n <= 1:
        return 1
    return n * factorial(n - 1)
print(factorial(5))

print("=== done ===")