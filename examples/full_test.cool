# Full test of working LLVM features
print("=== literals ===")
print(42)
print(3.14)
print(true)
print(false)
print(nil)

print("=== lists ===")
lst = [1, 2, 3]
print(lst)
print(len(lst))
print([1, 2] + [3, 4])

print("=== for loops ===")
for x in [1, 2, 3]:
    print(x)

print("=== range ===")
print(range(0, 3))

print("=== functions ===")
def double(x):
    return x * 2
print(double(5))

def add(a, b):
    return a + b
print(add(2, 3))

print("=== recursion ===")
def factorial(n):
    if n <= 1:
        return 1
    return n * factorial(n - 1)
print(factorial(5))

print("=== if/else ===")
if 1 < 2:
    print("less")
else:
    print("not less")

print("=== augmented assign ===")
x = 10
x += 5
print(x)

print("=== done ===")