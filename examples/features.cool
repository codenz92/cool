# ── 6. Closures ──────────────────────────────────────────────────────────────

print("=== closures ===")

def make_adder(x):
    def add(y):
        return x + y
    return add

add5 = make_adder(5)
add10 = make_adder(10)
print(add5(3))
print(add10(3))
print(add5(add10(1)))

def make_counter():
    count = 0
    def next():
        return count + 1
    def tick():
        return count
    return [next, tick]

counter_fns = make_counter()
nxt = counter_fns[0]
tick = counter_fns[1]
print(nxt())
print(tick())

# function returning function
def compose(f, g):
    def h(x):
        return f(g(x))
    return h

def double(x):
    return x * 2

def inc(x):
    return x + 1

double_then_inc = compose(inc, double)
print(double_then_inc(5))

# ── 7. Augmented assignment ───────────────────────────────────────────────────
print("=== augmented assignment ===")
x = 10
x += 5
print(x)
x -= 3
print(x)
x *= 2
print(x)
x /= 4
print(x)

# ── 8. List methods ───────────────────────────────────────────────────────────
print("=== list methods ===")
nums = [3, 1, 4, 1, 5, 9, 2, 6]
nums.sort()
print(nums)
nums.append(7)
print(nums)
nums.remove(1)
print(nums)
print(nums.contains(9))
print(nums.index(9))
print(sorted([5,3,1,4,2]))
print(reversed([1,2,3]))

# enumerate
for pair in enumerate(["a","b","c"]):
    print(pair[0], pair[1])
