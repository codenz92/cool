# ── 1. break / continue ──────────────────────────────────────────────────────

print("=== break / continue ===")

i = 0
while true:
    if i == 3:
        break
    print(i)
    i += 1

for n in range(10):
    if n % 2 == 0:
        continue
    if n > 7:
        break
    print(n)

# ── 2. Dicts ─────────────────────────────────────────────────────────────────

print("=== dicts ===")

person = {"name": "Jamie", "age": 25, "cool": true}
print(person["name"])
print(person["age"])

person["age"] = 26
print(person["age"])

print(person.keys())
print(person.values())
print(person.contains("cool"))
print(person.len())
person.remove("cool")
print(person.len())

# nested dict
config = {"db": {"host": "localhost", "port": 5432}}
print(config["db"]["host"])

# iterate dict keys
scores = {"alice": 90, "bob": 85, "carol": 95}
for name in scores:
    print(name + ": " + str(scores[name]))

# dict.items()
for pair in scores.items():
    print(pair[0] + " => " + str(pair[1]))

# ── 3. String methods ─────────────────────────────────────────────────────────

print("=== string methods ===")

msg = "  Hello, World!  "
print(msg.strip())
print(msg.strip().upper())
print(msg.strip().lower())
print("hello".startswith("he"))
print("hello".endswith("lo"))
print("hello world".contains("world"))
print("hello world".find("world"))
print("hello world".replace("world", "Cool"))
print("a,b,c".split(","))
print(",".join(["x", "y", "z"]))
print("ha".repeat(3))
print("42".to_int() + 8)
print("3.14".to_float())

